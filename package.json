{
  "name": "silo-actions",
  "version": "0.8.22",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "rm -rf .next && NODE_OPTIONS='--require ./scripts/indexeddb-polyfill.cjs' next dev",
    "prebuild": "node ./scripts/sync-manifest-version.mjs",
    "build": "NODE_OPTIONS='--require ./scripts/indexeddb-polyfill.cjs' next build",
    "start": "next start",
    "lint": "next lint --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "playwright test"
  },
  "dependencies": {
    "@base-org/account": "2.5.4",
    "@coinbase/wallet-sdk": "4.3.7",
    "@metamask/connect-evm": "0.9.1",
    "@safe-global/api-kit": "4.1.0",
    "@safe-global/protocol-kit": "7.0.0",
    "@safe-global/safe-apps-provider": "0.18.6",
    "@safe-global/safe-apps-sdk": "9.1.0",
    "@safe-global/types-kit": "3.1.0",
    "@tanstack/react-query": "5.59.0",
    "@walletconnect/ethereum-provider": "2.23.9",
    "accounts": "0.6.7",
    "ethers": "6.16.0",
    "next": "14.2.32",
    "porto": "0.2.37",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "strip-hex-prefix": "1.0.0",
    "three": "0.183.2",
    "viem": "2.48.0",
    "wagmi": "3.6.2"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/node": "20.10.5",
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.18",
    "@types/three": "0.183.1",
    "@typescript-eslint/eslint-plugin": "6.15.0",
    "@typescript-eslint/parser": "6.15.0",
    "autoprefixer": "10.4.16",
    "eslint": "8.56.0",
    "eslint-config-next": "14.0.4",
    "fake-indexeddb": "^6.2.5",
    "postcss": "8.4.32",
    "tailwindcss": "3.3.6",
    "typescript": "5.7.3",
    "vitest": "2.1.4"
  }
}
